  "keyFeatures": [
    "Floating chat overlay with customizable position and transparency",
    "Screen time tracking and watch statistics with visual charts",
    "Gesture-based video controls (volume, brightness, seek, playback speed)",
    "Material 3 design with dark theme support",
    "Privacy-first local data storage"
  ],
  "publicApiSurface": [
    "PlayerGestureListener - Gesture detection and handling",
    "PlayerGestureHelper - Gesture calculation utilities",
    "StatsRepository - Watch statistics data management",
    "ScreenTimeDao - Screen time database operations",
    "StreamWatchStatsDao - Stream watch statistics",
    "ChatAdapter - Chat message rendering",
    "PlayerFragment - Main video player interface",
    "StatsFragment - Statistics visualization"
